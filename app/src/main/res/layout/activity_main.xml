<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1B2F"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Orna Auto Battle"
        android:textColor="#F5A623"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Setup required"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <!-- Step 1: Overlay permission -->
    <Button
        android:id="@+id/btnOverlayPerm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Grant Overlay Permission"
        android:backgroundTint="#2D2D44"
        android:layout_marginBottom="12dp"/>

    <!-- Step 2: Accessibility -->
    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Enable Accessibility Service"
        android:backgroundTint="#2D2D44"
        android:layout_marginBottom="12dp"/>

    <!-- Step 3: Screen capture -->
    <Button
        android:id="@+id/btnScreenCapture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. Grant Screen Capture"
        android:backgroundTint="#2D2D44"
        android:layout_marginBottom="32dp"/>

    <!-- Launch overlay -->
    <Button
        android:id="@+id/btnLaunchOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Launch Overlay"
        android:backgroundTint="#F5A623"
        android:textColor="#000000"
        android:enabled="false"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Complete steps 1-3 to enable the overlay"
        android:textColor="#666666"
        android:textSize="12sp"
        android:layout_marginTop="16dp"/>

    <!-- Download monster sprites from the Orna codex -->
    <Button
        android:id="@+id/btnDownloadSprites"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download Monster Sprites (optional)"
        android:backgroundTint="#2D2D44"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvDownloadProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="8dp"/>

</LinearLayout>

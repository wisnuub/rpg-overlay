<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:minWidth="220dp">

    <!-- ── Compact bar (always visible) ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/barRow"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#E8101020"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <!-- Draggable left area: icon + dot + status -->
        <LinearLayout
            android:id="@+id/dragArea"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDragHandle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚔"
                android:textColor="#F5A623"
                android:textSize="16sp"
                android:paddingEnd="6dp"/>

            <TextView
                android:id="@+id/tvStatusDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#555555"
                android:textSize="10sp"
                android:paddingEnd="5dp"/>

            <TextView
                android:id="@+id/tvOverlayStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Idle"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:singleLine="true"
                android:ellipsize="end"/>

        </LinearLayout>

        <!-- Start / Stop -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="50dp"
            android:layout_height="34dp"
            android:text="▶"
            android:textSize="14sp"
            android:backgroundTint="#F5A623"
            android:textColor="#000000"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="2dp"/>

        <!-- Settings expand/collapse -->
        <Button
            android:id="@+id/btnSettings"
            android:layout_width="38dp"
            android:layout_height="34dp"
            android:text="⚙"
            android:textSize="14sp"
            android:backgroundTint="#2D2D44"
            android:textColor="#FFFFFF"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:layout_marginEnd="2dp"/>

    </LinearLayout>

    <!-- ── Expanded settings panel (hidden by default) ─────────── -->
    <ScrollView
        android:id="@+id/expandedPanel"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F0101020"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- W/L stats -->
            <TextView
                android:id="@+id/tvStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="W:0  L:0"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingBottom="6dp"/>

            <!-- Strategy picker -->
            <Spinner
                android:id="@+id/spinnerStrategy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"/>

            <!-- Capture sprite -->
            <Button
                android:id="@+id/btnCapture"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:text="+ Capture Sprite"
                android:textSize="11sp"
                android:backgroundTint="#2D2D44"
                android:textColor="#FFFFFF"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_marginBottom="4dp"/>

            <!-- Sprite count -->
            <TextView
                android:id="@+id/tvTemplateCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sprites: 0 (fallback)"
                android:textColor="#888888"
                android:textSize="10sp"
                android:gravity="center"
                android:paddingBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#44FFFFFF"
                android:layout_marginBottom="6dp"/>

            <!-- Auto buy toggle -->
            <CheckBox
                android:id="@+id/cbAutoBuy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-buy health potions"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:buttonTint="#F5A623"
                android:checked="false"
                android:layout_marginBottom="6dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#44FFFFFF"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AUTO BOOSTERS"
                android:textColor="#F5A623"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="4dp"/>

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox
                    android:id="@+id/cbBoosterExp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EXP Pot"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="true"/>
                <CheckBox
                    android:id="@+id/cbBoosterAffinity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Affinity"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="true"/>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox
                    android:id="@+id/cbBoosterLuckyCoin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lucky $"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="true"/>
                <CheckBox
                    android:id="@+id/cbBoosterLuckySilver"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lucky Ag"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="true"/>
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox
                    android:id="@+id/cbBoosterOccult"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Occult"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="false"/>
                <CheckBox
                    android:id="@+id/cbBoosterHallowed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hallowed"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="false"/>
            </LinearLayout>

            <!-- Row 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <CheckBox
                    android:id="@+id/cbBoosterDowse"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dowse"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="false"/>
                <CheckBox
                    android:id="@+id/cbBoosterTorch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Torch"
                    android:textColor="#DDDDDD"
                    android:textSize="10sp"
                    android:buttonTint="#F5A623"
                    android:checked="false"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

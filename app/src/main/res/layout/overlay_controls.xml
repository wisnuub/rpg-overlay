<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:scrollbars="none">

<LinearLayout
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:background="#CC1B1B2F"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Drag handle / title -->
    <TextView
        android:id="@+id/tvDragHandle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚔ OrnaAuto"
        android:textColor="#F5A623"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="6dp"/>

    <!-- Status -->
    <TextView
        android:id="@+id/tvOverlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Idle"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="4dp"/>

    <!-- W/L stats -->
    <TextView
        android:id="@+id/tvStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="W:0 L:0"
        android:textColor="#AAAAAA"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingBottom="6dp"/>

    <!-- Strategy picker -->
    <Spinner
        android:id="@+id/spinnerStrategy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"/>

    <!-- Start / Stop -->
    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:text="Start"
        android:textSize="12sp"
        android:backgroundTint="#F5A623"
        android:textColor="#000000"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:layout_marginBottom="4dp"/>

    <!-- Capture sprite -->
    <Button
        android:id="@+id/btnCapture"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:text="+ Capture Sprite"
        android:textSize="11sp"
        android:backgroundTint="#2D2D44"
        android:textColor="#FFFFFF"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:layout_marginBottom="4dp"/>

    <!-- Sprite count -->
    <TextView
        android:id="@+id/tvTemplateCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sprites: 0 (fallback)"
        android:textColor="#888888"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <!-- ── Divider ─────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginBottom="6dp"/>

    <!-- Auto buy toggle -->
    <CheckBox
        android:id="@+id/cbAutoBuy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Auto-buy potions"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:buttonTint="#F5A623"
        android:checked="false"
        android:layout_marginBottom="8dp"/>

    <!-- ── Divider ─────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginBottom="6dp"/>

    <!-- Boosters label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AUTO BOOSTERS"
        android:textColor="#F5A623"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="4dp"/>

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <CheckBox
            android:id="@+id/cbBoosterExp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EXP Pot"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="true"/>
        <CheckBox
            android:id="@+id/cbBoosterAffinity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Affinity"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="true"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <CheckBox
            android:id="@+id/cbBoosterLuckyCoin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lucky $"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="true"/>
        <CheckBox
            android:id="@+id/cbBoosterLuckySilver"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lucky Ag"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="true"/>
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <CheckBox
            android:id="@+id/cbBoosterOccult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Occult"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="false"/>
        <CheckBox
            android:id="@+id/cbBoosterHallowed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hallowed"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="false"/>
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        <CheckBox
            android:id="@+id/cbBoosterDowse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dowse"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="false"/>
        <CheckBox
            android:id="@+id/cbBoosterTorch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Torch"
            android:textColor="#DDDDDD"
            android:textSize="10sp"
            android:buttonTint="#F5A623"
            android:checked="false"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>
